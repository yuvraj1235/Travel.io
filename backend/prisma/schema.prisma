generator client {
  provider = "prisma-client-py"
}

datasource db {
  provider = "postgresql"
 // url      = env("DATABASE_URL")
}

model User {
  id           Int      @id @default(autoincrement())
  googleId     String   @unique
  email        String   @unique
  fullName     String?
  profilePic   String?
  trips        Trip[]
  createdAt    DateTime @default(now())
}

model Template {
  id           Int      @id @default(autoincrement())
  cityName     String
  country      String
  basePrice    Float
  imageUrl     String
  description  String
  durationDays Int
}

model Trip {
  id           Int      @id @default(autoincrement())
  userId       Int
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  destination  String
  budgetLimit  Float
  startDate    DateTime
  endDate      DateTime
  photoUrl     String?   // add this line
  itinerary    ItineraryItem[]
  createdAt    DateTime  @default(now())
}

model ItineraryItem {
  id              Int      @id @default(autoincrement())
  tripId          Int
  trip            Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  title           String
  itemType        String
  startTime       DateTime?
  endTime         DateTime?
  locationAddress String?
  googlePlaceId   String?
  photoUrl        String?
  cost            Float    @default(0.0)
}